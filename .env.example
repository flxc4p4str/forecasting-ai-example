# Database
# Local SQLite is the default and is enough for the POC.
DATABASE_URL=sqlite:///forecasting.db

# OpenAI
# Provide this to use live AI-assisted forecasting.
# Leave empty to use deterministic demo findings when DEMO_AI_WITHOUT_KEY=true.
# If using a restricted OpenAI project key, grant Responses access: create/write
# for POST /v1/responses and read for polling GET /v1/responses/{response_id}.
# The built-in web_search tool is invoked through the Responses API request.
OPENAI_API_KEY=

# Model used for live forecast analysis.
OPENAI_MODEL=gpt-5

# When true, the app works offline with deterministic sample findings.
# Set to false if you want missing OPENAI_API_KEY to fail AI jobs explicitly.
DEMO_AI_WITHOUT_KEY=true
